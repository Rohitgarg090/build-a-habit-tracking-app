# =============================================================
# HabitFlow Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# -------------------------------------------------------------
# SUPABASE CONFIGURATION
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------------------------

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
co

# Supabase anon/public key — safe to use in frontend
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key — BACKEND ONLY, never expose to frontend!
# Has full database access, bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT secret for verifying Supabase tokens (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# -------------------------------------------------------------
# BACKEND (Express) CONFIGURATION
# -------------------------------------------------------------

# Port for the Express API server
BACKEND_PORT=4000

# Environment: development | production | test
NODE_ENV=development

# CORS allowed origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# API rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------------------------
# FRONTEND (Next.js) CONFIGURATION
# Next.js requires NEXT_PUBLIC_ prefix for client-side variables
# -------------------------------------------------------------

# Supabase URL for the frontend client
co

# Supabase anon key for the frontend client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# App URL (used for redirects, OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name (used in UI and metadata)
NEXT_PUBLIC_APP_NAME=HabitFlow

# -------------------------------------------------------------
# OPTIONAL: ANALYTICS & MONITORING
# -------------------------------------------------------------

# Vercel Analytics (auto-populated on Vercel deployments)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# -------------------------------------------------------------
# OPTIONAL: EMAIL (for auth emails via Supabase)
# Configure in Supabase dashboard under Authentication → Email
# -------------------------------------------------------------

# Custom SMTP (optional, Supabase has built-in email)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=noreply@yourapp.com